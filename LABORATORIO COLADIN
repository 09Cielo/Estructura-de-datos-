#include "Cola.h"
using namespace std;

Cola::Cola() {
    inicio = NULL;
    fin = NULL;
}

bool Cola::estaVacia() {
    return inicio == NULL;
}

void Cola::encolar() {
    Nodo* nuevo = new Nodo;

    cout << "ID: ";
    cin >> nuevo->dato.ID;

    cin.ignore();
    cout << "Titulo: ";
    getline(cin, nuevo->dato.Titulo);

    cout << "Precio: ";
    cin >> nuevo->dato.precio;

    nuevo->siguiente = NULL;

    if (estaVacia()) {
        inicio = fin = nuevo;
    }
    else {
        fin->siguiente = nuevo;
        fin = nuevo;
    }
}

void Cola::desencolar() {
    if (!estaVacia()) {
        Nodo* temp = inicio;

        cout << "\nElemento eliminado:\n";
        cout << "ID: " << temp->dato.ID << endl;
        cout << "Titulo: " << temp->dato.Titulo << endl;
        cout << "Precio: " << temp->dato.precio << endl;

        inicio = inicio->siguiente;

        if (inicio == NULL) {
            fin = NULL;
        }

        delete temp;
    }
    else {
        cout << "La cola esta vacia\n";
    }
    void Cola::mostrar() {
        if (estaVacia()) {
            cout << "La cola esta vacia\n";
            return;
        }

        Nodo* actual = inicio;

        cout << "\n--- CONTENIDO DE LA COLA ---\n";

        while (actual != NULL) {
            cout << "ID: " << actual->dato.ID << endl;
            cout << "Titulo: " << actual->dato.Titulo << endl;
            cout << "Precio: " << actual->dato.precio << endl;
            cout << "---------------------------\n";

            actual = actual->siguiente;
        }
    }
    void Cola::mostrar() {
