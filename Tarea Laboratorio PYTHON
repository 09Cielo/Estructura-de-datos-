def factorial(n):
    if n == 0 or n == 1:
        return 1
    else:
        resultado = n * factorial(n - 1)
        return resultado

def tabla(numero, contador):
    if contador <= 10:
        print(numero, "+", contador, "=", numero + contador)
        tabla(numero, contador + 1)

def hexa(numero):
    if numero < 100:
        print(numero, "en hexadecimal es", hex(numero))
        hexa(numero + 1)

opcion = -1

