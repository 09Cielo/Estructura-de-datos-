string quitarvocales(string texto) {
	string resultado = ""; 

	for (int i = 0; i < texto.length(); i++)
	{
		char aux = texto[i];
		if (aux != 'a' && aux != 'e' && aux != 'i' && aux != 'o' && aux != 'u' &&
			aux != 'A' && aux != 'E' && aux != 'I' && aux != 'O' && aux != 'U') {
			resultado = resultado + aux; 
		}
	}

	return resultado;
}
